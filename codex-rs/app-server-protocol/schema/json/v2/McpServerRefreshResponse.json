{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "McpServerRefreshResponse",
  "type": "object",
  "required": [
    "refreshedThreads",
    "skippedThreads"
  ],
  "properties": {
    "refreshedThreads": {
      "type": "integer",
      "format": "uint32",
      "minimum": 0.0
    },
    "skippedThreads": {
      "type": "integer",
      "format": "uint32",
      "minimum": 0.0
    }
  }
}
